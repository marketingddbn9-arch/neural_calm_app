# Neural Calm - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials

# ============================================
# Firebase Configuration
# ============================================
# Get these from your Firebase Console
# https://console.firebase.google.com

# Firebase Project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase API Key
FIREBASE_API_KEY=your-api-key

# Firebase App ID
FIREBASE_APP_ID=your-app-id

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Database URL (if using Realtime Database)
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# ============================================
# API Configuration
# ============================================

# API Base URL
API_BASE_URL=https://api.neuralcalm.com/v1

# API Timeout (milliseconds)
API_TIMEOUT=30000

# API Retry Count
API_RETRY_COUNT=3

# ============================================
# Application Configuration
# ============================================

# App Environment (development, staging, production)
APP_ENV=development

# App Name
APP_NAME=Neural Calm

# App Version
APP_VERSION=1.0.0

# Log Level (debug, info, warning, error)
LOG_LEVEL=debug

# Enable Logging to Console
ENABLE_CONSOLE_LOGGING=true

# Enable Logging to File
ENABLE_FILE_LOGGING=false

# ============================================
# Feature Flags
# ============================================

# Enable Analytics
ENABLE_ANALYTICS=true

# Enable Crash Reporting
ENABLE_CRASH_REPORTING=true

# Enable Push Notifications
ENABLE_PUSH_NOTIFICATIONS=true

# Enable AI Coaching
ENABLE_AI_COACHING=true

# Enable Offline Mode
ENABLE_OFFLINE_MODE=true

# ============================================
# Security Configuration
# ============================================

# JWT Secret (only for testing, use environment variable in production)
JWT_SECRET=your-secret-key

# API Key for External Services
EXTERNAL_API_KEY=your-external-api-key

# Certificate Pinning Enabled
CERTIFICATE_PINNING_ENABLED=true

# ============================================
# Third-party Services
# ============================================

# Sentry DSN (for crash reporting)
SENTRY_DSN=

# Amplitude API Key (for analytics)
AMPLITUDE_API_KEY=

# Mixpanel Token (for analytics)
MIXPANEL_TOKEN=

# ============================================
# UI Configuration
# ============================================

# Primary Color (Hex)
PRIMARY_COLOR=#7C5CFA

# Enable Dark Mode
ENABLE_DARK_MODE=true

# Animation Duration (milliseconds)
ANIMATION_DURATION=300

# ============================================
# Development Configuration
# ============================================

# Use Mock Data
USE_MOCK_DATA=false

# Mock API Delay (milliseconds)
MOCK_API_DELAY=500

# Show Debug Info
SHOW_DEBUG_INFO=true

# Enable Network Logging
ENABLE_NETWORK_LOGGING=true

# ============================================
# Notifications Configuration
# ============================================

# Daily Check-in Reminder Time (HH:MM format)
DAILY_CHECKIN_REMINDER_TIME=09:00

# Enable Local Notifications
ENABLE_LOCAL_NOTIFICATIONS=true

# Enable Remote Notifications
ENABLE_REMOTE_NOTIFICATIONS=true

# ============================================
# Database Configuration
# ============================================

# Database Name
DATABASE_NAME=neural_calm

# Database Version
DATABASE_VERSION=1

# Enable Database Encryption
ENABLE_DATABASE_ENCRYPTION=true

# ============================================
# Testing Configuration
# ============================================

# Test Mode Enabled
TEST_MODE_ENABLED=false

# Test API Base URL
TEST_API_BASE_URL=http://localhost:3000/v1

# ============================================
# Notes
# ============================================
# 1. Never commit sensitive data to version control
# 2. Use this file as a template for local development
# 3. Each developer should create their own .env file
# 4. In production, use environment variables directly
# 5. Keep all secrets in a secure location
# 6. Rotate credentials regularly
# 7. Use different credentials for different environments
